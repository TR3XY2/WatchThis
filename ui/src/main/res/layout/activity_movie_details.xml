<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/wt_bg" android:orientation="vertical">
    <com.google.android.material.appbar.MaterialToolbar android:id="@+id/toolbarDetails" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@color/wt_primary" android:title="@string/toolbar_movie_details" android:titleTextColor="@color/white"/>
    <androidx.core.widget.NestedScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="14dp">
            <ImageView android:id="@+id/ivPosterDetails" android:layout_width="180dp" android:layout_height="260dp" android:layout_gravity="center_horizontal" android:contentDescription="@string/movie_poster_cd" android:scaleType="centerCrop"/>
            <TextView android:id="@+id/tvDetails" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:textColor="@color/wt_text" android:textSize="15sp"/>
            <TextView android:id="@+id/tvPhrasesLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:layout_marginBottom="4dp" android:text="@string/movie_details_phrases_label" android:textColor="@color/wt_text" android:textSize="15sp" android:textStyle="bold"/>
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvPhrases" android:layout_width="match_parent" android:layout_height="wrap_content" android:nestedScrollingEnabled="false"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    <Button android:id="@+id/btnAddFavorite" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="12dp" android:text="@string/add_to_favorites"/>
    <include layout="@layout/include_app_bottom_nav"/>
</LinearLayout>